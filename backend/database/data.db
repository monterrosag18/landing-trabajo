CREATE DATABASE IF NOT EXISTS supcrud_by_crudzaso;
USE supcrud_by_crudzaso;

-- 1. USERS
CREATE TABLE users (
    id INT NOT NULL AUTO_INCREMENT,
    email VARCHAR(255) NOT NULL,
    password_hash VARCHAR(255),
    full_name VARCHAR(150) NOT NULL,
    oauth_provider VARCHAR(50),
    is_global_owner INT NOT NULL DEFAULT 0,
    created_at DATE NOT NULL,

    PRIMARY KEY (id),
    UNIQUE (email)
);

-- 2. WORKSPACES
CREATE TABLE workspaces (
    id INT NOT NULL AUTO_INCREMENT,
    owner_id INT NOT NULL,
    workspace_key VARCHAR(80) NOT NULL,
    name VARCHAR(150) NOT NULL,
    status VARCHAR(20) NOT NULL DEFAULT 'ACTIVE',
    ai_mode VARCHAR(20),
    created_at DATE NOT NULL,

    PRIMARY KEY (id),
    UNIQUE (workspace_key),

    FOREIGN KEY (owner_id)
        REFERENCES users(id)
);

-- 3. ADDONS
CREATE TABLE addons (
    id INT NOT NULL AUTO_INCREMENT,
    slug VARCHAR(60) NOT NULL,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(255),
    is_active_global INT NOT NULL DEFAULT 1,

    PRIMARY KEY (id),
    UNIQUE (slug)
);

-- 4. WORKSPACE_MEMBERS
CREATE TABLE workspace_members (
    id INT NOT NULL AUTO_INCREMENT,
    user_id INT NOT NULL,
    workspace_id INT NOT NULL,
    role VARCHAR(20) NOT NULL,
    joined_at DATE NOT NULL,

    PRIMARY KEY (id),

    UNIQUE (user_id, workspace_id),

    FOREIGN KEY (user_id)
        REFERENCES users(id),

    FOREIGN KEY (workspace_id)
        REFERENCES workspaces(id)
);

-- 5. AGENT_PREFERENCES
CREATE TABLE agent_preferences (
    id INT NOT NULL AUTO_INCREMENT,
    member_id INT NOT NULL,
    preference_type VARCHAR(20) NOT NULL,
    value VARCHAR(100) NOT NULL,

    PRIMARY KEY (id),

    FOREIGN KEY (member_id)
        REFERENCES workspace_members(id)
);

-- 6. WORKSPACE_ADDONS
CREATE TABLE workspace_addons (
    id INT NOT NULL AUTO_INCREMENT,
    workspace_id INT NOT NULL,
    addon_id INT NOT NULL,
    is_active INT NOT NULL DEFAULT 0,
    activated_at DATE,

    PRIMARY KEY (id),

    UNIQUE (workspace_id, addon_id),

    FOREIGN KEY (workspace_id)
        REFERENCES workspaces(id),

    FOREIGN KEY (addon_id)
        REFERENCES addons(id)
);

-- 7. EVENT_TYPES
CREATE TABLE event_types (
    id INT NOT NULL AUTO_INCREMENT,
    code VARCHAR(60) NOT NULL,
    label VARCHAR(100) NOT NULL,
    description VARCHAR(255),

    PRIMARY KEY (id),
    UNIQUE (code)
);

-- 8. TICKET_REFERENCES
CREATE TABLE ticket_references (
    id INT NOT NULL AUTO_INCREMENT,
    reference_code VARCHAR(30) NOT NULL,
    workspace_id INT NOT NULL,
    user_email VARCHAR(255) NOT NULL,
    created_at DATE NOT NULL,

    PRIMARY KEY (id),

    UNIQUE (reference_code),

    FOREIGN KEY (workspace_id)
        REFERENCES workspaces(id)
);

-- 9. TICKET_EVENTS
CREATE TABLE ticket_events (
    id INT NOT NULL AUTO_INCREMENT,
    ticket_ref_id INT NOT NULL,
    actor_member_id INT,
    event_type_id INT NOT NULL,
    is_system_event INT NOT NULL DEFAULT 0,
    created_at DATE NOT NULL,

    PRIMARY KEY (id),

    FOREIGN KEY (ticket_ref_id)
        REFERENCES ticket_references(id),

    FOREIGN KEY (actor_member_id)
        REFERENCES workspace_members(id),

    FOREIGN KEY (event_type_id)
        REFERENCES event_types(id)
);

-- 10. OTP_CODES
CREATE TABLE otp_codes (
    id INT NOT NULL AUTO_INCREMENT,
    ticket_ref_id INT NOT NULL,
    email VARCHAR(255) NOT NULL,
    code_hash VARCHAR(255) NOT NULL,
    expires_at DATE NOT NULL,
    attempts INT NOT NULL DEFAULT 0,
    is_used INT NOT NULL DEFAULT 0,
    created_at DATE NOT NULL,

    PRIMARY KEY (id),

    FOREIGN KEY (ticket_ref_id)
        REFERENCES ticket_references(id)
);

-- 11. ATTACHMENTS
CREATE TABLE attachments (
    id INT NOT NULL AUTO_INCREMENT,
    ticket_ref_id INT NOT NULL,
    cloudinary_url VARCHAR(500) NOT NULL,
    public_id VARCHAR(255) NOT NULL,
    file_name VARCHAR(255) NOT NULL,
    mime_type VARCHAR(100),
    uploaded_at DATE NOT NULL,

    PRIMARY KEY (id),

    FOREIGN KEY (ticket_ref_id)
        REFERENCES ticket_references(id)
);

-- 12. INVITATION_TOKENS
CREATE TABLE invitation_tokens (
    id INT NOT NULL AUTO_INCREMENT,
    workspace_id INT NOT NULL,
    invited_by INT NOT NULL,
    email VARCHAR(255) NOT NULL,
    token_hash VARCHAR(255) NOT NULL,
    role VARCHAR(20) NOT NULL DEFAULT 'AGENT',
    expires_at DATE NOT NULL,
    is_used INT NOT NULL DEFAULT 0,
    created_at DATE NOT NULL,

    PRIMARY KEY (id),

    FOREIGN KEY (workspace_id)
        REFERENCES workspaces(id),

    FOREIGN KEY (invited_by)
        REFERENCES workspace_members(id)
);


